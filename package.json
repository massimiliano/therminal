{
  "name": "therminal-2",
  "version": "1.0.0",
  "description": "Launcher multi-sessione per CLI AI con terminali embedded.",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "rebuild-pty": "electron-rebuild -f -w node-pty",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.therminal.app",
    "productName": "Therminal",
    "npmRebuild": false,
    "afterPack": "./after-pack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "styles.css",
      "logo.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "logo.ico",
      "uninstallerIcon": "logo.ico",
      "installerHeaderIcon": "logo.ico"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  }
}
